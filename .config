# ===== Netgear R6220 / MT7621 =====
CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt7621=y
CONFIG_TARGET_ramips_mt7621_DEVICE_netgear_r6220=y

# ===== LuCI 基础 =====
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-ssl=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-theme-bootstrap=y
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y

# ===== HomeProxy + sing-box =====
CONFIG_PACKAGE_luci-app-homeproxy=y
CONFIG_PACKAGE_luci-i18n-homeproxy-zh-cn=y
CONFIG_PACKAGE_sing-box=y

# ===== HomeProxy / TProxy 必需依赖 =====
CONFIG_PACKAGE_ca-bundle=y
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_kmod-tun=y
CONFIG_PACKAGE_kmod-inet-diag=y
CONFIG_PACKAGE_kmod-nft-socket=y
CONFIG_PACKAGE_kmod-nft-tproxy=y

# ===== WiFi 驱动 =====
CONFIG_PACKAGE_kmod-mt7603=y
CONFIG_PACKAGE_kmod-mt7612=y
CONFIG_PACKAGE_wpad-basic-mbedtls=y

# ===== 基础网络 =====
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_nftables=y

# ===== 实用工具 =====
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-i18n-ttyd-zh-cn=y
CONFIG_PACKAGE_nano=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget-ssl=y

# ===== 系统优化 =====
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_fdisk=y
CONFIG_PACKAGE_lsblk=y

# ===== 禁用 USB =====
# CONFIG_PACKAGE_kmod-usb-core is not set
# CONFIG_PACKAGE_kmod-usb2 is not set
# CONFIG_PACKAGE_kmod-usb3 is not set
# CONFIG_PACKAGE_kmod-usb-storage is not set
# CONFIG_PACKAGE_kmod-usb-printer is not set
# CONFIG_PACKAGE_kmod-usb-net is not set

# ===== 禁用 Docker =====
# CONFIG_PACKAGE_luci-app-docker is not set
# CONFIG_PACKAGE_dockerd is not set
# CONFIG_PACKAGE_containerd is not set

# ===== 禁用代理重复插件 =====
# CONFIG_PACKAGE_luci-app-passwall is not set
# CONFIG_PACKAGE_luci-app-passwall2 is not set
# CONFIG_PACKAGE_luci-app-openclash is not set
# CONFIG_PACKAGE_luci-app-ssr-plus is not set

# ===== 禁用 NAS / Samba =====
# CONFIG_PACKAGE_luci-app-samba4 is not set
# CONFIG_PACKAGE_samba4-server is not set

# ===== 禁用 IPv6 =====
# CONFIG_PACKAGE_odhcp6c is not set
# CONFIG_PACKAGE_odhcpd-ipv6only is not set
# CONFIG_PACKAGE_dnsmasq_full_dhcpv6 is not set
# CONFIG_PACKAGE_ipv6helper is not set
# CONFIG_PACKAGE_ip6tables-nft is not set

# ===== 禁用 PPPoE（旁路由通常不需要） =====
# CONFIG_PACKAGE_ppp is not set
# CONFIG_PACKAGE_ppp-mod-pppoe is not set
# CONFIG_PACKAGE_ppp-mod-pppoa is not set

# ===== 禁用 UPnP =====
# CONFIG_PACKAGE_luci-app-upnp is not set
# CONFIG_PACKAGE_miniupnpd is not set

# ===== 禁用 WOL =====
# CONFIG_PACKAGE_luci-app-wol is not set

# ===== 禁用打印/多媒体 =====
# CONFIG_PACKAGE_kmod-video-core is not set
# CONFIG_PACKAGE_kmod-sound-core is not set

# ===== 保持系统精简 =====
# CONFIG_PACKAGE_luci-app-qos is not set
# CONFIG_PACKAGE_luci-app-statistics is not set
# CONFIG_PACKAGE_luci-app-nlbwmon is not set
# CONFIG_PACKAGE_luci-app-watchcat is not set
# CONFIG_PACKAGE_luci-app-accesscontrol is not set
# CONFIG_PACKAGE_luci-app-filetransfer is not set

# ===== 可选保留 =====
CONFIG_PACKAGE_openssh-sftp-server=y
CONFIG_PACKAGE_zlib=y
